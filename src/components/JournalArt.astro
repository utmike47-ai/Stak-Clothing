---
import type { JournalPost } from '../data/products';

interface Props {
  post: JournalPost;
  variant?: 'card' | 'article';
}

const { post, variant = 'card' } = Astro.props;
const wrapperClass = variant === 'article' ? 'article-art' : 'journal-art';
---
{post.image ? (
  <div class={`${wrapperClass} journal-art-photo`}>
    <img
      src={post.image}
      alt=""
      class="journal-photo"
      loading="lazy"
      decoding="async"
    />
  </div>
) : (
  <div class={`${wrapperClass} ${post.artClass}`}></div>
)}
