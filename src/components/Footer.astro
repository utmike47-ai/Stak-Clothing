---
import LogoMark from './LogoMark.astro';
---
<footer class="footer">
  <div class="footer-top">
    <div class="footer-brand">
      <LogoMark class="grid-mark grid-mark-large" />
      <p>Style That Always Keeps.</p>
      <p class="footer-location">Austin, Texas · Est. 2026</p>
    </div>

    <div class="footer-cols">
      <div class="footer-col">
        <h4>Shop</h4>
        <a href="/shop">Drop 001</a>
        <a href="/shop">All products</a>
        <a href="/shop/washed-dad-hat">Headwear</a>
        <a href="/shop">Archive</a>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <a href="/story">Our Story</a>
        <a href="/field-notes">The Journal</a>
        <a href="/story">Sustainability</a>
        <a href="mailto:hello@stakclothing.com?subject=Press">Press</a>
      </div>
      <div class="footer-col">
        <h4>Help</h4>
        <a href="/sizing">Sizing</a>
        <a href="/shipping">Shipping</a>
        <a href="/returns">Returns</a>
        <a href="/contact">Contact</a>
      </div>
      <div class="footer-col">
        <h4>Follow</h4>
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://open.spotify.com" target="_blank" rel="noopener noreferrer">Spotify</a>
        <a href="mailto:hello@stakclothing.com?subject=Newsletter">Newsletter</a>
      </div>
    </div>
  </div>

  <div class="footer-wordmark" aria-hidden="true">stak</div>

  <div class="footer-bottom">
    <p>© 2026 STAK. All rights reserved.</p>
    <div class="footer-bottom-right">
      <a href="mailto:hello@stakclothing.com?subject=Privacy">Privacy</a>
      <a href="mailto:hello@stakclothing.com?subject=Terms">Terms</a>
      <a href="mailto:hello@stakclothing.com?subject=Accessibility">Accessibility</a>
    </div>
  </div>
</footer>
