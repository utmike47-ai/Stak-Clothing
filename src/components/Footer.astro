---
import LogoMark from './LogoMark.astro';
---
<footer class="footer">
  <div class="footer-top">
    <div class="footer-brand">
      <LogoMark class="grid-mark grid-mark-large" />
      <p>Style That Always Keeps.</p>
      <p class="footer-location">Austin, Texas · Est. 2026</p>
    </div>

    <div class="footer-cols">
      <div class="footer-col">
        <h4>Shop</h4>
        <a href="/#drop">Drop 001</a>
        <a href="/shop">All products</a>
        <a href="/shop/washed-dad-hat">Headwear</a>
        <a href="/shop">Archive</a>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <a href="/#story">Our Story</a>
        <a href="/journal">The Journal</a>
        <a href="/#story">Sustainability</a>
        <a href="mailto:press@staksupply.co">Press</a>
      </div>
      <div class="footer-col">
        <h4>Help</h4>
        <a href="mailto:hello@staksupply.co?subject=Sizing">Sizing</a>
        <a href="mailto:hello@staksupply.co?subject=Shipping">Shipping</a>
        <a href="mailto:hello@staksupply.co?subject=Returns">Returns</a>
        <a href="mailto:hello@staksupply.co">Contact</a>
      </div>
      <div class="footer-col">
        <h4>Follow</h4>
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://tiktok.com" target="_blank" rel="noopener noreferrer">TikTok</a>
        <a href="https://open.spotify.com" target="_blank" rel="noopener noreferrer">Spotify</a>
        <a href="/#signup">Newsletter</a>
      </div>
    </div>
  </div>

  <div class="footer-wordmark" aria-hidden="true">stak</div>

  <div class="footer-bottom">
    <p>© 2026 STAK Supply Co. All rights reserved.</p>
    <div class="footer-bottom-right">
      <a href="mailto:hello@staksupply.co?subject=Privacy">Privacy</a>
      <a href="mailto:hello@staksupply.co?subject=Terms">Terms</a>
      <a href="mailto:hello@staksupply.co?subject=Accessibility">Accessibility</a>
    </div>
  </div>
</footer>
