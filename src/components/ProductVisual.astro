---
import type { Product } from '../data/products';

interface Props {
  product: Product;
  view?: 'listing' | 'detail';
}

const { product, view = 'listing' } = Astro.props;
const imageClass = product.variant === 'tee' ? 'product-tee' : 'product-hat';
const photoSrc = view === 'detail' ? product.detailImage : product.image;
---
<div class={`product-image ${imageClass} product-image-photo`}>
  <div class="garment-tag">{product.tag}</div>
  <img
    src={photoSrc}
    alt={product.imageAlt}
    class="product-photo"
    loading={view === 'detail' ? 'eager' : 'lazy'}
    decoding="async"
  />
</div>
