---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact — Get in Touch | STAK Clothing"
  description="Contact STAK in Austin, Texas. Email hello@stakclothing.com — we read everything."
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Contact', path: '/contact' },
  ]}
>
  <main>
    <section class="page-hero">
      <p class="eyebrow">Help</p>
      <h1 class="display">Contact.</h1>
    </section>

    <section class="story-page-prose info-page">
      <div class="story-page-prose-inner">
        <p class="lede">
          <a href="mailto:hello@stakclothing.com" class="link-underline">hello@stakclothing.com</a>
        </p>
        <p>austin, texas</p>
        <p>we read everything.</p>
      </div>
    </section>
  </main>
</BaseLayout>
