---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductVisual from '../../components/ProductVisual.astro';
import ShopifyBuyButton from '../../components/ShopifyBuyButton.astro';
import { products } from '../../data/products';
import { productJsonLd } from '../../lib/structured-data';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const canonical = new URL(`/shop/${product.slug}`, Astro.site);
---
<BaseLayout
  title={product.pageTitle}
  description={product.description}
  ogImage={product.detailImage}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Shop', path: '/shop' },
    { name: product.name, path: `/shop/${product.slug}` },
  ]}
  jsonLd={[productJsonLd(product, Astro.site!, canonical)]}
>
  <main>
    <section class="page-hero" style="padding-bottom: 40px;">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/shop">Shop</a>
        <span>/</span>
        <span>{product.name}</span>
      </nav>
    </section>

    <div class="product-detail">
      <div class="product-detail-media">
        <ProductVisual product={product} view="detail" />
        {product.badge === 'dropped' && <div class="product-badge" style="position:absolute;top:18px;right:18px;">Just Dropped</div>}
        {product.badge === 'soon' && <div class="product-badge product-badge-soon" style="position:absolute;top:18px;right:18px;">Coming Soon</div>}
      </div>

      <div class="product-detail-info">
        <p class="eyebrow">Drop 001 · No. {product.tag}</p>
        <h1>{product.name}</h1>
        <p class="product-detail-price">${product.price}</p>
        <p class="product-meta">{product.meta}</p>
        <p class="product-detail-desc">{product.description}</p>
        <ul class="product-detail-list">
          {product.details.map((detail) => <li>{detail}</li>)}
        </ul>
        <div class="product-detail-actions">
          {product.shopifyBuy ? (
            <div class="product-detail-shopify">
              <ShopifyBuyButton
                componentId={product.shopifyBuy.componentId}
                productId={product.shopifyBuy.productId}
              />
            </div>
          ) : product.available ? (
            <button type="button" class="btn btn-primary" data-add-to-cart>
              Add to Cart — ${product.price}
            </button>
          ) : (
            <button type="button" class="btn btn-primary btn-disabled" disabled>
              Coming Soon
            </button>
          )}
          <a href="/shop" class="btn btn-ghost-dark product-detail-back">Back to Drop 001</a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
