---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Returns & Exchanges — Size Swaps Available | STAK"
  description="All sales are final on limited runs. Size exchanges available — email hello@stakclothing.com to arrange."
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Returns', path: '/returns' },
  ]}
>
  <main>
    <section class="page-hero">
      <p class="eyebrow">Help</p>
      <h1 class="display">Returns.</h1>
    </section>

    <section class="story-page-prose info-page">
      <div class="story-page-prose-inner">
        <p class="lede">we run small batches. when a piece is gone, it's gone — so all sales are final.</p>
        <p>that said, if the size isn't right, we'll swap you for another size on the same item when we have it in stock. no hassle, just email us.</p>
        <p>reach out at <a href="mailto:hello@stakclothing.com" class="link-underline-sm">hello@stakclothing.com</a> and we'll get it handled.</p>
      </div>
    </section>
  </main>
</BaseLayout>
