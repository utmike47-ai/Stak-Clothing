---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Sizing — Drop 001 Tee & Dad Hat | STAK"
  description="Size chart for the STAK Drop 001 tee and washed dad hat. Relaxed fit tee in S–XL. Hat is one size fits most."
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Sizing', path: '/sizing' },
  ]}
>
  <main>
    <section class="page-hero">
      <p class="eyebrow">Help</p>
      <h1 class="display">Sizing.</h1>
    </section>

    <section class="story-page-prose info-page">
      <div class="story-page-prose-inner">
        <p class="lede">drop 001 tee runs true to size with a relaxed fit. measurements below are flat across the chest and shoulder to hem.</p>

        <div class="size-chart-wrap">
          <h2 class="size-chart-title">Drop 001 Tee</h2>
          <table class="size-chart">
            <thead>
              <tr>
                <th scope="col">Size</th>
                <th scope="col">Chest</th>
                <th scope="col">Length</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>S</td><td>20"</td><td>27"</td></tr>
              <tr><td>M</td><td>21.5"</td><td>28"</td></tr>
              <tr><td>L</td><td>23"</td><td>29"</td></tr>
              <tr><td>XL</td><td>24.5"</td><td>30"</td></tr>
            </tbody>
          </table>
        </div>

        <p>washed dad hat is one size fits most — adjustable brass buckle, unstructured six-panel cotton.</p>
        <p>not sure? email <a href="mailto:hello@stakclothing.com" class="link-underline-sm">hello@stakclothing.com</a> and we'll help you pick.</p>
      </div>
    </section>
  </main>
</BaseLayout>
