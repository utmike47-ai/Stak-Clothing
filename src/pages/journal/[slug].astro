---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JournalArt from '../../components/JournalArt.astro';
import { journalPosts } from '../../data/products';
import { articleJsonLd } from '../../lib/structured-data';

export function getStaticPaths() {
  return journalPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const canonical = new URL(`/journal/${post.slug}`, Astro.site);
---
<BaseLayout
  title={post.pageTitle}
  description={post.excerpt}
  ogImage={post.image}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Field Notes', path: '/journal' },
    { name: post.title, path: `/journal/${post.slug}` },
  ]}
  jsonLd={[articleJsonLd(post, Astro.site!, canonical)]}
>
  <main>
    <section class="page-hero journal-post-hero">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/journal">Field Notes</a>
        <span>/</span>
        <span>{post.title}</span>
      </nav>
    </section>

    <article class="article-page journal-article">
      <JournalArt post={post} variant="article" />
      <header class="journal-article-header">
        <div class="journal-meta">
          <span>{post.date}</span>
          <span>·</span>
          <span>{post.readTime}</span>
        </div>
        <h1>{post.title}</h1>
      </header>
      <div class="journal-article-body">
        {post.body.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
      <a href="/journal" class="link-underline">← All entries</a>
    </article>
  </main>
</BaseLayout>
