---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { journalPosts, getJournalPost } from '../../data/products';

export function getStaticPaths() {
  return journalPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---
<BaseLayout title={post.title} description={post.excerpt}>
  <main>
    <section class="page-hero" style="padding-bottom: 0;">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/journal">Journal</a>
        <span>/</span>
        <span>{post.title}</span>
      </nav>
      <div class="journal-meta" style="margin-top: 24px;">
        <span>{post.date}</span>
        <span>·</span>
        <span>{post.readTime}</span>
      </div>
    </section>

    <article class="article-page">
      <div class={`article-art ${post.artClass}`}></div>
      <h1>{post.title}</h1>
      {post.body.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
      <a href="/journal" class="link-underline">← All entries</a>
    </article>
  </main>
</BaseLayout>
