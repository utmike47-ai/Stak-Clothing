---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Shipping — Free USPS Delivery | STAK"
  description="Free shipping via USPS. Most orders arrive in 3–5 business days. Local pickup available in Austin, Texas."
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Shipping', path: '/shipping' },
  ]}
>
  <main>
    <section class="page-hero">
      <p class="eyebrow">Help</p>
      <h1 class="display">Shipping.</h1>
    </section>

    <section class="story-page-prose info-page">
      <div class="story-page-prose-inner">
        <p class="lede">free shipping on every order. we send everything via usps.</p>
        <p>most orders land in 3–5 business days once they leave austin. you'll get tracking when your package ships.</p>
        <p>local pickup is available in austin — email <a href="mailto:hello@stakclothing.com" class="link-underline-sm">hello@stakclothing.com</a> and we'll sort out a time.</p>
      </div>
    </section>
  </main>
</BaseLayout>
