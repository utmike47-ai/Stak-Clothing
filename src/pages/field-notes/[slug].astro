---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import JournalArt from '../../components/JournalArt.astro';
import JournalBody from '../../components/JournalBody.astro';
import { journalPosts } from '../../data/products';
import { articleJsonLd } from '../../lib/structured-data';

type FieldNoteEntry = CollectionEntry<'field-notes'>;

export async function getStaticPaths() {
  const entries = await getCollection('field-notes');
  const bySlug = new Map(entries.map((entry) => [entry.id, entry]));

  return journalPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post, entry: bySlug.get(post.slug) ?? null },
  }));
}

interface Props {
  post: (typeof journalPosts)[number];
  entry: FieldNoteEntry | null;
}

const { post, entry } = Astro.props;
const { Content } = entry ? await render(entry) : { Content: null };
const canonical = new URL(`/field-notes/${post.slug}`, Astro.site);
---
<BaseLayout
  title={post.pageTitle}
  description={post.excerpt}
  ogImage={post.image}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Field Notes', path: '/field-notes' },
    { name: post.title, path: `/field-notes/${post.slug}` },
  ]}
  jsonLd={[articleJsonLd(post, Astro.site!, canonical)]}
>
  <main>
    <section class="page-hero journal-post-hero">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/field-notes">Field Notes</a>
        <span>/</span>
        <span>{post.title}</span>
      </nav>
    </section>

    <article class="article-page journal-article">
      <JournalArt post={post} variant="article" />
      <header class="journal-article-header">
        <div class="journal-meta">
          <span>{post.date}</span>
          <span>·</span>
          <span>{post.readTime}</span>
        </div>
        <h1>{post.title}</h1>
      </header>
      <div class="journal-article-body">
        {Content ? <Content /> : <JournalBody body={post.body} />}
      </div>
      <a href="/field-notes" class="link-underline">← All entries</a>
    </article>
  </main>
</BaseLayout>
