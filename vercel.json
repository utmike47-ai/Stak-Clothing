{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "astro",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "stakclothing.com"
        }
      ],
      "destination": "https://www.stakclothing.com/:path*",
      "permanent": true
    }
  ]
}
